# restic + Cloudflare R2 credentials. Copy to `restic.env` (gitignored) and fill in.
# R2 is S3-compatible. Create an R2 bucket + an API token (Access Key ID / Secret) in
# the Cloudflare dashboard (R2 > Manage R2 API Tokens). Pick a STRONG, SAVED restic
# password — losing it means losing the ability to decrypt backups.

# Repo URL: s3:https://<ACCOUNT_ID>.r2.cloudflarestorage.com/<BUCKET>
RESTIC_REPOSITORY=s3:https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com/hermes-box-backups

# Encryption password for the restic repo (save this somewhere safe, e.g. a password manager).
RESTIC_PASSWORD=CHANGE_ME_to_a_long_random_passphrase

# R2 API token credentials.
AWS_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY

# R2 ignores region but the S3 client wants one set.
AWS_DEFAULT_REGION=auto
