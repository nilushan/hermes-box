# Per-machine overrides for the hermes-box scripts.
# Copy to .env and edit. All are optional; defaults derive from the current user/host.

# HERMES_BOX_USER=hermes                # SSH login user (the Hermes image ships 'hermes')
# HERMES_BOX_NAME=hermes-box            # container name (also default TS hostname)
# HERMES_BOX_TS_HOSTNAME=hermes-box     # tailnet/MagicDNS hostname
# HERMES_BOX_IMAGE=local/hermes-box:latest
# HERMES_BOX_CPUS=4
# HERMES_BOX_MEMORY=4G

# Data (consolidated, backup-friendly root; subdirs keep original names):
# HERMES_BOX_DATA_ROOT="$HOME/AiInfra/hermes-box-data"   # holds .hermes/ + hermes-home/
# HERMES_BOX_BACKUP_DIR="$HOME/AiInfra/hermes-box-backups"
# HERMES_BOX_BACKUP_EXCLUDES=".cache .npm node_modules .playwright"

# Hermes runtime:
# HERMES_BOX_PUID=501                   # default: id -u
# HERMES_BOX_PGID=20                    # default: id -g
# HERMES_BOX_GATEWAY_PORT=9119          # host port -> 9119 (gateway + dashboard UI)
# HERMES_BOX_DASHBOARD_PORT=8642        # host port -> 8642

# Infra:
# HERMES_BOX_STATE_VOLUME=hermes-box-tsstate        # named volume: tailscale identity
# HERMES_BOX_AUTOSTART_LABEL=local.hermes-box.boot  # launchd agent label

# One-time migration source (only used by scripts/migrate-data.sh):
# HERMES_BOX_OLD_DATA="$HOME/.hermes"
# HERMES_BOX_OLD_WORK="$HOME/AiInfra/hermes-home"
