# Per-machine overrides for the hermes-box scripts.
# Copy to .env and edit. All are optional; defaults derive from the current user/host.

# HERMES_BOX_USER=nilushan              # box username (default: your login name)
# HERMES_BOX_UID=501                    # default: id -u
# HERMES_BOX_GID=20                     # default: id -g
# HERMES_BOX_HOME="$HOME/hermes-home"   # host folder mounted as the box home
# HERMES_BOX_NAME=hermes-box            # container name (also default TS hostname)
# HERMES_BOX_TS_HOSTNAME=hermes-box     # tailnet/MagicDNS hostname
# HERMES_BOX_IMAGE=local/hermes-box:latest
# HERMES_BOX_CPUS=4
# HERMES_BOX_MEMORY=4G
# HERMES_BOX_STATE_VOLUME=hermes-box-tsstate  # named volume for tailscale identity
# HERMES_BOX_AUTOSTART_LABEL=local.hermes-box.boot  # launchd agent label
