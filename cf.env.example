# Cloudflare credentials for scripts/cf-r2-setup.sh. Copy to `cf.env` (gitignored).
#
# Create an API token: dash.cloudflare.com > My Profile > API Tokens > Create Token >
# Custom token, with permission:  Account > Workers R2 Storage > Edit  (your account).
# Account ID: shown on the R2 overview page / in the dashboard URL.

CF_API_TOKEN=your_cloudflare_api_token
CF_ACCOUNT_ID=your_account_id

# Optional bucket name (default: hermes-box-backups)
# HERMES_BOX_R2_BUCKET=hermes-box-backups
